<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══ Header ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔒 Content Blocker"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Service বন্ধ"
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Accessibility Service চালু করো →"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- ══ Section label ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  🛡️ DETECTION LAYERS"
            android:textColor="#777777"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="4dp"/>

        <!-- Master switch -->
        <LinearLayout style="@style/RowCard"
            android:layout_marginBottom="1dp">
            <LinearLayout style="@style/RowText">
                <TextView style="@style/RowTitle" android:text="Blocking চালু / বন্ধ"/>
                <TextView style="@style/RowSub"   android:text="সব ধরনের blocking একসাথে চালু বা বন্ধ করো"/>
            </LinearLayout>
            <Switch android:id="@+id/switchEnabled"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Hard adult text -->
        <LinearLayout style="@style/RowCard"
            android:layout_marginBottom="1dp">
            <LinearLayout style="@style/RowText">
                <TextView style="@style/RowTitle" android:text="🔞 Hard Adult Block"/>
                <TextView style="@style/RowSub"   android:text="Porn, xxx, sex video — সরাসরি adult keyword ও site"/>
            </LinearLayout>
            <Switch android:id="@+id/switchAdultText"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Soft adult -->
        <LinearLayout style="@style/RowCard"
            android:background="#0F1F1F"
            android:layout_marginBottom="1dp">
            <LinearLayout style="@style/RowText">
                <TextView style="@style/RowTitle" android:text="🌶️ Soft Adult Block"/>
                <TextView style="@style/RowSub"   android:text="hot girl, item song, sexy dance — browser ও video app-এ"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="শুধু Browser ও Video app-এ কাজ করে"
                    android:textColor="#E65100"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <Switch android:id="@+id/switchSoftAdult"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Video metadata -->
        <LinearLayout style="@style/RowCard"
            android:background="#0A1A0A"
            android:layout_marginBottom="16dp">
            <LinearLayout style="@style/RowText">
                <TextView style="@style/RowTitle" android:text="🎬 Video Metadata Check"/>
                <TextView style="@style/RowSub"   android:text="Video চলার সময় title, tag, hashtag দেখে block করে"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen-এ text না থাকলেও কাজ করে ✅"
                    android:textColor="#388E3C"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <Switch android:id="@+id/switchVideoMeta"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ══ Keywords ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  🚫 আমার Keywords"
                android:textColor="#777777"
                android:textSize="10sp"
                android:letterSpacing="0.12"/>
            <Button
                android:id="@+id/btnImportJson"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="📂 JSON"
                android:backgroundTint="#2A2A2A"
                android:textColor="#AAAAAA"
                android:paddingHorizontal="10dp"
                android:textSize="11sp"
                android:layout_marginEnd="6dp"/>
            <Button
                android:id="@+id/btnAdd"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="+ যোগ"
                android:backgroundTint="#BF360C"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="সব app-এ এই keyword দেখলে block হবে • Long press করে মুছো"
            android:textColor="#444444"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/listKeywords"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#141414"
            android:divider="#1E1E1E"
            android:dividerHeight="1dp"
            android:layout_marginBottom="16dp"/>

        <!-- ══ Whitelist ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  ✅ Whitelist"
                android:textColor="#777777"
                android:textSize="10sp"
                android:letterSpacing="0.12"/>
            <Button
                android:id="@+id/btnAddWhitelist"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="✏️ Edit Apps"
                android:backgroundTint="#1B5E20"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="12dp"
                android:textSize="11sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="এই app-গুলোতে কোনো block হবে না • Checkbox দিয়ে বেছে নাও • Long press → সরাও"
            android:textColor="#444444"
            android:textSize="10sp"
            android:layout_marginBottom="4dp"/>

        <ListView
            android:id="@+id/listWhitelist"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#141414"
            android:divider="#1E1E1E"
            android:dividerHeight="1dp"/>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Video Metadata Check চালু থাকলে video-র title ও hashtag-এ adult word থাকলেও block হবে — screen-এ text না থাকলেও।"
            android:textColor="#2A2A2A"
            android:textSize="11sp"
            android:lineSpacingExtra="3dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
